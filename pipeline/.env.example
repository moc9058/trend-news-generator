# Local development only — production uses Secret Manager via --set-secrets.
PROJECT_ID=trend-news-generator
REGION=asia-northeast1
GCS_BUCKET=trend-news-generator-media
PIPELINE_SERVICE_ACCOUNT=pipeline-sa@trend-news-generator.iam.gserviceaccount.com

OPENAI_API_KEY=
GEMINI_API_KEY=
X_CREDENTIALS={"consumer_key":"","consumer_secret":"","access_token":"","access_token_secret":""}
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
NOTION_API_KEY=
IEEE_API_KEY=

# LangSmith tracing (optional). Needs both TRACING=true and a key to activate.
# Prompts/completions are sent in full to LangSmith's US SaaS when enabled.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=trend-news-generator
